# Server
PORT=3003
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/timetable-service?retryWrites=true&w=majority

# Auth Service URL
AUTH_SERVICE_URL=http://localhost:3001

# Course Service URL (inter-service communication)
COURSE_SERVICE_URL=http://localhost:3002

# JWT (shared secret)
JWT_SECRET=your-super-secret-jwt-key-change-this

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3004

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
